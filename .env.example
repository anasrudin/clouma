# Database
DATABASE_URL=postgresql+asyncpg://clouma:clouma@localhost:5432/clouma
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# LLM provider (OpenAI-compatible Chat Completions API)
# ─────────────────────────────────────────────────────────────
# Any inference endpoint exposing the OpenAI API works here.
# Pick ONE block and fill in LLM_API_KEY. Comment out the rest.

# --- NVIDIA NIM (default) ─────────────────────────────────────
# Get key: https://build.nvidia.com  →  "Get API Key"
# Models: https://build.nvidia.com/explore/discover
# Notes: supports response_format={"type":"json_object"}; strict
# json_schema varies by model — code falls back to Pydantic validate.
LLM_PROVIDER=nvidia
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.1-70b-instruct
LLM_API_KEY=nvapi-REPLACE_ME

# --- OpenAI ───────────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-REPLACE_ME

# --- Anthropic via OpenAI-compatible proxy (e.g. LiteLLM) ─────
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=http://localhost:4000/v1
# LLM_MODEL=claude-haiku-4-5
# LLM_API_KEY=sk-ant-REPLACE_ME

# --- Ollama (local, free) ─────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=ollama

# ─────────────────────────────────────────────────────────────
# Tavily web search (for web_search tool)
# Get key: https://app.tavily.com
# ─────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-REPLACE_ME
# Custom endpoint (optional, default: https://api.tavily.com)
# TAVILY_BASE_URL=https://api.tavily.com

# ─────────────────────────────────────────────────────────────
# Python sandbox provider for run_python tool
# Options: subprocess (default, unsandboxed) | docker (local) | e2b (remote)
# ─────────────────────────────────────────────────────────────
PYTHON_SANDBOX=subprocess
# E2B remote sandbox — get key: https://e2b.dev
# E2B_API_KEY=e2b-REPLACE_ME

# ─────────────────────────────────────────────────────────────
# Secret encryption key (AES-256-GCM for agent credentials)
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to store secrets as plaintext (not recommended for prod).
# ─────────────────────────────────────────────────────────────
# SECRET_ENCRYPTION_KEY=
